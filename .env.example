# Copy to `.env.local` and replace secrets. Never commit `.env.local`.

# --- Postgres (Supabase) ---
# Direct connection (db host). Supabase may show "Not IPv4 compatible" — if you are
# on IPv4-only networks, use the "Session pooler" connection string from the
# Supabase Dashboard (Settings → Database) instead of this URL.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.qjlibvnecwigaurmicun.supabase.co:5432/postgres

# Supabase client (browser + server). Use the project URL and publishable key
# from the Supabase Dashboard (API / Settings). Legacy dashboards may label the
# key "anon" — either works with createClient.
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_or_anon_key
#
# Server-only: required for POST /api/email-capture (notify-me signups → public.email_captures).
# Dashboard → Settings → API → service_role (never expose to the browser or NEXT_PUBLIC_*).
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
#
# Database: migrations define public.products, public.roll_up_bookings,
# public.fresh_hit_bookings, public.event_quote_requests, public.email_captures
# (see supabase/migrations or Supabase SQL editor). Regenerate types: Supabase MCP generate_typescript_types.
